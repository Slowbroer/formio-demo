generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Form {
  id        String   @id @db.VarChar(36)
  name      String   @db.VarChar(255)
  schema    Json
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("forms")
}

model FormDefinition {
  id         String        @id @db.VarChar(36)
  name       String        @db.VarChar(255)
  definition Json
  createdAt  DateTime      @default(now()) @map("created_at")
  updatedAt  DateTime      @updatedAt @map("updated_at")
  submits    FormSubmit[]

  @@map("form_definitions")
}

model FormSubmit {
  id               String         @id @db.VarChar(36)
  formDefinitionId String        @map("form_definition_id") @db.VarChar(36)
  submission       Json
  createdAt        DateTime       @default(now()) @map("created_at")

  formDefinition  FormDefinition @relation(fields: [formDefinitionId], references: [id], onDelete: Cascade)

  @@index([formDefinitionId, createdAt])
  @@map("form_submits")
}

